# Phase 7B NVIDIA single-provider runtime baseline.
# Copy values into your shell or local .env; never commit real secrets.
# This template is placeholder-only. It is not a production secret vault.

NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=

# Optional model import / chat provider keys. Leave blank in this template.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

AI_GATEWAY_PROVIDER_MODE=real
AI_GATEWAY_REAL_PROVIDER_ENABLED=true
AI_GATEWAY_ROUTE_MODE=fixed
AI_GATEWAY_DEFAULT_PROVIDER=nvidia
AI_GATEWAY_ENABLED_PROVIDERS=nvidia

AI_GATEWAY_SERVICE_HOST=127.0.0.1
AI_GATEWAY_SERVICE_PORT=3100
AI_GATEWAY_SERVICE_URL=http://127.0.0.1:3100

AI_GATEWAY_REQUEST_TIMEOUT_MS=60000
AI_GATEWAY_CONSOLE_TIMEOUT_MS=60000
# Set true only when using the Phase 8A streaming console path.
AI_GATEWAY_CONSOLE_STREAM=false
