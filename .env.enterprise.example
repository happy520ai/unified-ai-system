# PME 移动地球 enterprise deployment template.
# Copy values into your local shell, secret manager, or private .env file.
# Never commit real API keys, database passwords, auth tokens, or pooler URIs.

# ------------------------------------------------------------
# Service endpoint
# ------------------------------------------------------------
AI_GATEWAY_SERVICE_HOST=127.0.0.1
AI_GATEWAY_SERVICE_PORT=3100
AI_GATEWAY_SERVICE_URL=http://127.0.0.1:3100

# ------------------------------------------------------------
# Default NVIDIA single-provider chat lane
# ------------------------------------------------------------
AI_GATEWAY_PROVIDER_MODE=real
AI_GATEWAY_REAL_PROVIDER_ENABLED=true
AI_GATEWAY_ROUTE_MODE=fixed
AI_GATEWAY_DEFAULT_PROVIDER=nvidia
AI_GATEWAY_ENABLED_PROVIDERS=nvidia
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_API_KEY=<set-in-local-secret-store>
AI_GATEWAY_REQUEST_TIMEOUT_MS=60000
AI_GATEWAY_CONSOLE_TIMEOUT_MS=60000

# ------------------------------------------------------------
# Durable local knowledge store for daily use
# ------------------------------------------------------------
KNOWLEDGE_STORAGE_MODE=file-sqlite
KNOWLEDGE_PERSISTENCE_DIR=.data/knowledge

# ------------------------------------------------------------
# Optional explicit vector / pgvector production path
# Keep disabled unless you are validating vector production readiness.
# Use the Supabase pooler URI, not the direct db.<project>.supabase.co:5432 host.
# ------------------------------------------------------------
KNOWLEDGE_INFRA_MODE=local-keyword
# KNOWLEDGE_INFRA_MODE=vector
# KNOWLEDGE_EMBEDDING_PROVIDER=gemini
# KNOWLEDGE_EMBEDDING_MODEL=gemini-embedding-001
# KNOWLEDGE_EMBEDDING_API_KEY=<set-in-local-secret-store>
# KNOWLEDGE_VECTOR_STORE=pgvector
# PGVECTOR_CONNECTION_STRING=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# PGVECTOR_TABLE=knowledge_chunks
# KNOWLEDGE_VECTOR_NAMESPACE=default

# ------------------------------------------------------------
# Enterprise auth / tenant / audit / backup
# ------------------------------------------------------------
PME_ENTERPRISE_AUTH_ENABLED=true
PME_AUTH_TOKEN=<set-in-local-secret-store>
PME_AUTH_USER_ID=enterprise-admin
PME_AUTH_TENANT_ID=default
PME_AUTH_ROLE=admin
PME_AUTH_EXPIRES_AT=2026-12-31T23:59:59.000Z
PME_ENTERPRISE_USER_STORE_PATH=.data/enterprise/users.json
PME_AUDIT_LOG_PATH=.data/audit/enterprise-audit.jsonl
PME_ENTERPRISE_BACKUP_DIR=.data/enterprise/backups

# Optional: comma-separated raw tokens or token hashes to reject.
# PME_ENTERPRISE_REVOKED_TOKENS=
