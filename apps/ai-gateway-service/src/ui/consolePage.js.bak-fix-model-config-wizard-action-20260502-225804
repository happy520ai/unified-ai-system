      setText("loop-status-go-nogo", data.latestGoNoGo || "需要人工判断");
      setText("loop-status-blocker", data.currentBlocker || "none");
      setText("loop-status-next-action", data.recommendedNextAction || "请人工判断下一步");
      const desktopAutomation = data.desktopAutomation || {};
      setText("desktop-automation-mode", desktopAutomation.currentMode || "dry-run / copy-only / paste-only / send-with-approval / inbox review");
      setText("desktop-outbox-task", formatStatusBool(desktopAutomation.outboxTaskExists, "outbox task exists=true；可以 dry-run/copy/paste", "outbox task exists=false；请先生成下一条任务"));
