      const text = recommendedCodexTaskBody?.value || "";
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        if (recommendedCodexTaskCopyStatus) recommendedCodexTaskCopyStatus.textContent = "已复制。现在可以手动粘贴给 Codex。";
      } catch {
        recommendedCodexTaskBody?.focus();
        recommendedCodexTaskBody?.select();
        if (recommendedCodexTaskCopyStatus) recommendedCodexTaskCopyStatus.textContent = "浏览器未允许自动复制，已选中文本，可以按 Ctrl+C。";
