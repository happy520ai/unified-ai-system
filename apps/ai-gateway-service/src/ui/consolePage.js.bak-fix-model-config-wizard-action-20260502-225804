      return select?.value || "feature-development";
    }

    async function refreshWorkforceHistory() {
      const target = document.getElementById("workforce-history");
      if (!target) return;
      const result = await requestJson("/workforce/plans");
      if (!result.ok) {
        target.replaceChildren(createWorkforceNotice("Saved plan history cannot be read yet: " + formatWorkforceError(result), "error"));
        return;
      }
      renderWorkforceHistory(result.payload?.data?.plans || []);
    }

    function renderWorkforceHistory(plans) {
      const target = document.getElementById("workforce-history");
      if (!target) return;
      target.replaceChildren();

      const heading = document.createElement("div");
      heading.className = "workforce-status";
      heading.dataset.phase = "phase187a-history-detail-polish";
      heading.setAttribute("aria-label", "Phase187A History / Saved Plan Detail Polish: selectedTemplate, plan state, createdAt, Execution Disabled; no execution button is provided.");
      target.appendChild(heading);
      heading.textContent = "Saved plans / history UX hardening (Phase166A). Phase187A History / Saved Plan Detail Polish: plan id, selected template, selectedTemplate, createdAt, plan state, execution disabled, Execution Disabled; no execution button is provided. Total: " + plans.length + ".";

      if (!plans.length) {
        target.appendChild(createWorkforceNotice("No saved plans yet. Generate and save a preview-only Plan to see plan id, selectedTemplate, createdAt, plan state, and Execution Disabled here."));
