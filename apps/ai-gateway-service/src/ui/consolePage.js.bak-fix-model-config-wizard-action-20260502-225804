    function collectProviderOptions(providersResult) {
      const collectedByValue = new Map();
      const addOption = (optionInfo) => {
        if (!optionInfo || !isVisibleProviderValue(optionInfo.value || "")) return;
        if (collectedByValue.has(optionInfo.value || "")) {
          collectedByValue.set(optionInfo.value || "", {
            ...collectedByValue.get(optionInfo.value || ""),
            ...optionInfo,
            capabilities: optionInfo.capabilities?.length
              ? optionInfo.capabilities
              : collectedByValue.get(optionInfo.value || "")?.capabilities || [],
          });
          return;
        }
        collectedByValue.set(optionInfo.value || "", optionInfo);
      };

      addOption({ value: "", label: "server auto route" });
      for (const option of Array.from(providerSelect.options)) {
        addOption({
          value: option.value,
          label: option.textContent || option.value || "server auto route",
          endpoint: option.dataset.endpoint || "",
          apiKeyRef: option.dataset.apiKeyRef || "",
          modelImportSource: option.dataset.modelImportSource || "",
          capabilities: String(option.dataset.capabilities || "").split(",").map((item) => item.trim()).filter(Boolean),
          runtimeCredentialPersisted: option.dataset.runtimeCredentialPersisted === "true",
          runtimeCredentialStorage: option.dataset.runtimeCredentialStorage || "",
        });
      }
      const providers = providersResult.payload?.data ?? providersResult.payload ?? [];
      for (const provider of Array.isArray(providers) ? providers : []) {
        for (const model of provider.models ?? []) {
          if (!isVisibleProviderModel(provider.id, model.id)) continue;
          if (!isProviderChatCapableModel(model)) continue;
          addOption({
            value: provider.id + "::" + model.id,
            label: (provider.displayName || provider.id) + " / " + (model.displayName || model.id),
            endpoint: provider.suggestedEndpoint || model.metadata?.providerEndpoint || "",
            capabilities: Array.isArray(model.capabilities) ? model.capabilities : [],
            modelImportSource: model.metadata?.source || provider.metadata?.source || "",
            runtimeCredentialPersisted: provider.metadata?.runtimeCredentialPersisted === true,
            runtimeCredentialStorage: provider.metadata?.runtimeCredentialStorage || "",
          });
        }
      }
      return Array.from(collectedByValue.values());
    }

