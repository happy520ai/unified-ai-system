    async function openModelConfigDialog() {
      modelConfigDialogBody.replaceChildren();
      const assistant = createModelConfigDialogMessage();
      modelConfigDialogBody.appendChild(assistant);
      setMessageText(assistant, "正在打开模型配置...");
      setMessageStatus(assistant, "正在读取 provider 和运行配置...", "active");
