        appendMessage("system", "当前正在生成回答，完成后再打开模型配置。", "system");
        return;
      }
      pendingModelConfigOpenContext = composerModelStatus?.dataset.modelRecoveryRequired === "true"
        ? createModelConfigRepairContext()
        : null;
      if (modelConfigDialog && modelConfigDialogBody) {
        await openModelConfigDialog();
      } else {
        await handleChatCommandCenter("配置模型");
      }
      if (!modelConfigDialog?.open) input.focus();
      syncComposerState();
    }

    async function openModelConfigDialog() {
      if (!modelConfigDialog || !modelConfigDialogBody) {
        await handleChatCommandCenter("配置模型");
        return;
      }
      modelConfigDialogBody.replaceChildren();
      const assistant = createModelConfigDialogMessage();
