    function createFullModelLibrary({ providers, optionValues }) {
      const providerList = providers?.payload?.data ?? providers?.payload ?? [];
      const optionByValue = new Map((Array.isArray(optionValues) ? optionValues : []).map((option) => [option.value, option]));
      const providersById = new Map();
      const ensureProvider = (providerId, displayName, metadata = {}) => {
        if (!providerId) return null;
        if (!providersById.has(providerId)) {
          providersById.set(providerId, {
            providerId,
            displayName: displayName || providerId,
            metadata,
            modelsById: new Map(),
          });
        }
        return providersById.get(providerId);
      };

      for (const provider of Array.isArray(providerList) ? providerList : []) {
        if (!provider?.id || isFakeProviderModel(provider.id, "")) continue;
        const target = ensureProvider(provider.id, provider.displayName || provider.id, provider.metadata || {});
        for (const model of Array.isArray(provider.models) ? provider.models : []) {
          if (!model?.id || !isVisibleProviderModel(provider.id, model.id)) continue;
          const selectValue = provider.id + "::" + model.id;
          target.modelsById.set(model.id, normalizeLibraryModel({
            provider,
            model,
            optionInfo: optionByValue.get(selectValue),
            selectValue,
          }));
        }
      }

      for (const option of Array.isArray(optionValues) ? optionValues : []) {
        if (!option?.value) continue;
        const { providerId, modelId } = splitProviderModel(option.value);
        if (!providerId || !modelId || isFakeProviderModel(providerId, modelId)) continue;
        const target = ensureProvider(providerId, providerId, {});
        if (target.modelsById.has(modelId)) continue;
        target.modelsById.set(modelId, normalizeLibraryModel({
          provider: { id: providerId, displayName: providerId, metadata: {} },
          model: {
            id: modelId,
            displayName: option.label?.includes(" / ") ? option.label.split(" / ").slice(1).join(" / ") : modelId,
            capabilities: option.capabilities || ["chat"],
            enabled: true,
            metadata: { source: option.modelImportSource || "ui-option" },
          },
          optionInfo: option,
          selectValue: option.value,
        }));
      }

      const capabilityCounts = { chat: 0, vision: 0, video: 0, image: 0, coding: 0 };
      const providersOut = Array.from(providersById.values())
        .map((provider) => {
          const models = Array.from(provider.modelsById.values()).sort((a, b) => a.modelId.localeCompare(b.modelId));
          for (const model of models) {
            for (const capability of Object.keys(capabilityCounts)) {
              if (model.flags[capability]) capabilityCounts[capability] += 1;
            }
          }
          return { ...provider, models };
        })
        .filter((provider) => provider.models.length)
        .sort((a, b) => a.displayName.localeCompare(b.displayName));

      return {
        providers: providersOut,
        totalModels: providersOut.reduce((sum, provider) => sum + provider.models.length, 0),
        capabilityCounts,
      };
    }

    function normalizeLibraryModel({ provider, model, optionInfo, selectValue }) {
      const capabilityTags = normalizeModelLibraryCapabilityTags(model, optionInfo);
      const flags = createModelLibraryCapabilityFlags({ model, capabilityTags });
      return {
        providerId: provider.id,
        modelId: model.id || model.modelId,
        displayName: model.displayName || model.modelDisplayName || model.id || model.modelId,
        enabled: model.enabled !== false,
        capabilityTags,
        flags,
        selectValue: flags.chat ? selectValue : "",
        runtimeDiscovered: model.metadata?.runtimeDiscovered === true ||
          model.metadata?.source === "provider_models_api" ||
          optionInfo?.modelImportSource === "provider_models_api",
        runtimeCredentialPersisted: provider.metadata?.runtimeCredentialPersisted === true ||
          optionInfo?.runtimeCredentialPersisted === true ||
          model.metadata?.persistedRuntimeModel === true,
      };
    }

    function normalizeModelLibraryCapabilityTags(model, optionInfo) {
      const tags = new Set();
      for (const capability of [
        ...(Array.isArray(model?.capabilities) ? model.capabilities : []),
        ...(Array.isArray(optionInfo?.capabilities) ? optionInfo.capabilities : []),
      ]) {
        const normalized = String(capability || "").trim().toLowerCase();
        if (!normalized) continue;
        if (normalized === "completion" || normalized === "native-chat") tags.add("chat");
        else if (normalized === "image") tags.add("image-generation");
        else if (normalized === "video") tags.add("video-generation");
        else tags.add(normalized);
      }
      if (!tags.size) tags.add("unknown");
      return Array.from(tags).sort();
    }

    function createModelLibraryCapabilityFlags({ model, capabilityTags }) {
      const tags = new Set(capabilityTags);
      const modalities = model?.metadata?.modalities || model?.modalities || {};
      const inputText = JSON.stringify(modalities?.input || modalities?.inputs || modalities?.inputModalities || []).toLowerCase();
      const outputText = JSON.stringify(modalities?.output || modalities?.outputs || modalities?.outputModalities || []).toLowerCase();
      const modelText = String((model?.id || model?.modelId || "") + " " + (model?.displayName || model?.modelDisplayName || "")).toLowerCase();
      return {
        chat: tags.has("chat") || tags.has("summary") || tags.has("reasoning") || tags.has("coding"),
        vision: tags.has("vision") || tags.has("ocr") || tags.has("image-input") || inputText.includes("image"),
        video: tags.has("video-generation") || tags.has("text-to-video") || tags.has("video") || inputText.includes("video") || outputText.includes("video"),
        image: tags.has("image-generation") || tags.has("text-to-image") || tags.has("image") || outputText.includes("image"),
        coding: tags.has("coding") || /\b(code|coder|coding)\b/.test(modelText),
      };
    }

