      setText("desktop-go-nogo", desktopAutomation.latestGoNoGo || data.latestGoNoGo || "pending-review");
      setText("desktop-next-action", desktopAutomation.recommendedNextAction || data.recommendedNextAction || "请人工判断下一步");
