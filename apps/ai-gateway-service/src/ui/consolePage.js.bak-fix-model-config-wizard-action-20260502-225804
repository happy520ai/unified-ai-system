    function createModelProviderCoverage({ providers, runtimeData, optionValues }) {
      const liveProviders = providers?.payload?.data ?? providers?.payload ?? [];
      const providerList = Array.isArray(liveProviders) ? liveProviders : [];
      const runtimeModels = Array.isArray(runtimeData?.aiGatewayService?.providerModels)
        ? runtimeData.aiGatewayService.providerModels
        : [];
      const liveById = new Map(providerList.map((provider) => [provider.id, provider]));
      const providerIds = new Set([
        ...runtimeModels.map((model) => model.providerId).filter(Boolean),
        ...providerList.map((provider) => provider.id).filter(Boolean),
      ]);
      const rows = Array.from(providerIds)
        .filter((providerId) => !isFakeProviderModel(providerId, ""))
        .sort((a, b) => {
          const aLive = liveById.get(a)?.models?.length ? 0 : 1;
          const bLive = liveById.get(b)?.models?.length ? 0 : 1;
          return aLive - bLive || a.localeCompare(b);
        })
        .map((providerId) => {
          const live = liveById.get(providerId);
          const templates = runtimeModels.filter((model) => model.providerId === providerId);
          const liveModelCount = (live?.models ?? []).filter((model) => isVisibleProviderModel(providerId, model.id)).length;
          const enabled = liveModelCount > 0 || templates.some((model) => model.enabled === true);
          const apiKeyPresent = live?.metadata?.apiKeyPresent === true ||
            live?.metadata?.runtimeCredentialPresent === true ||
            templates.some((model) => model.apiKeyPresent === true);
          const endpointPresent = live?.metadata?.endpointConfigured === true ||
            templates.some((model) => model.hasEndpoint === true);
          const runtimeCredentialPersisted = live?.metadata?.runtimeCredentialPersisted === true;
          const templateModelIds = templates.map((model) => model.modelId).filter(Boolean);
          let status = "hidden";
          let reason = "Not shown yet; select this provider, paste a key, then run model detection.";
          if (liveModelCount > 0) {
            status = "available";
            reason = "Shown in the model dropdown now.";
          } else if (!templates.length) {
            status = "runtime-only";
            reason = "No static template; use OpenAI-compatible with Base URL or import from models/list.";
          } else if (!enabled) {
            status = "not-enabled";
            reason = "Template exists but provider is not enabled yet.";
          } else if (!apiKeyPresent) {
            status = "missing-key";
            reason = "Provider is known, but no API key is active for this local service.";
          } else if (!endpointPresent) {
            status = "missing-endpoint";
            reason = "API key may exist, but endpoint/Base URL is not configured.";
          } else {
            status = "configured-no-chat-models";
            reason = "Configured, but /providers has not returned chat-capable models.";
          }
          return {
            providerId,
            displayName: live?.displayName || providerId,
            status,
            reason,
            liveModelCount,
            templateModelCount: templates.length,
            templateModels: templateModelIds.slice(0, 3),
            runtimeCredentialPersisted,
          };
        });
      const availableModelCount = (optionValues || []).filter((option) => option.value).length;
      return {
        availableModelCount,
        catalogProviderCount: rows.length,
        hiddenProviderCount: rows.filter((row) => row.status !== "available").length,
        rows,
      };
    }

    function safeCreateModelProviderCoverage(input) {
      try {
        return createModelProviderCoverage(input);
      } catch (error) {
        return {
          availableModelCount: (input?.optionValues || []).filter((option) => option.value).length,
          catalogProviderCount: 0,
          hiddenProviderCount: 0,
          rows: [{
            providerId: "coverage-error",
            displayName: "Provider coverage",
            status: "diagnostic-error",
            reason: "Coverage summary failed to render, but model detection can still run: " + describeError(error),
            liveModelCount: 0,
            templateModelCount: 0,
            templateModels: [],
            runtimeCredentialPersisted: false,
          }],
        };
      }
    }

