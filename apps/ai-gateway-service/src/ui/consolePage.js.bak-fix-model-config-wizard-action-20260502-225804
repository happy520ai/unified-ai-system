    function isProviderChatCapableModel(model) {
      const capabilities = Array.isArray(model?.capabilities)
        ? model.capabilities.map((item) => String(item).toLowerCase())
        : [];
      return capabilities.includes("chat") ||
        capabilities.includes("completion") ||
        capabilities.includes("native-chat") ||
        capabilities.includes("reasoning") ||
        capabilities.includes("coding");
    }

