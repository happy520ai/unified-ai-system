      if (!recommendedCodexTaskBody) return;
      const result = await requestJson("/codex-handoff/next-task");
      const data = result.payload?.data;
      if (result.ok && data?.markdown) {
        recommendedCodexTaskBody.value = data.markdown;
        if (recommendedCodexTaskCopyStatus) recommendedCodexTaskCopyStatus.textContent = "已自动生成下一条推荐任务，仍需人工复制给 Codex。";
      } else if (recommendedCodexTaskCopyStatus) {
        recommendedCodexTaskCopyStatus.textContent = "未能从服务端刷新任务正文，保留页面内置版本。";
      }
    }

    async function refreshAutoLoopStatusPanel() {
      const result = await requestJson("/codex-loop/status");
      const data = result.payload?.data;
      if (!result.ok || !data) {
        setText("loop-status-next-action", "状态读取失败，请运行 cmd /c pnpm run codex:loop:status。");
        if (autoLoopStatusUpdated) autoLoopStatusUpdated.textContent = "状态读取失败：" + (result.payload?.error?.message || "未知错误");
        return;
      }

      setText("loop-status-next-task", formatStatusBool(data.nextTaskExists, "已有下一条任务", "没有任务：请先生成下一条 Codex 任务"));
      setText("loop-status-outbox", formatStatusBool(data.outboxTaskExists, "有 outbox：请复制任务给 Codex", "outbox 任务不存在"));
      setText("loop-status-inbox", formatStatusBool(data.inboxResultExists, "有 inbox：请审查 Codex 返回结果", "inbox 暂无结果"));
