    function renderWorkforcePlan(plan) {
      const target = document.getElementById("workforce-rendered");
      if (!target) return;
      target.replaceChildren();
      if (!plan) {
        renderWorkforceEmptyState(target);
        return;
      }

      const summary = document.createElement("div");
      summary.className = "result";
      const title = document.createElement("strong");
      title.textContent = plan.userFriendlyStatus === "ready_to_review" ? "Plan generated for human review" : "Plan Preview";
      const text = document.createElement("p");
      text.className = "muted";
      text.textContent = plan.summary || plan.goal || "";
      summary.append(title, text);
      target.appendChild(summary);

      appendWorkforceList(target, "计划信息", [
        "版本：" + (plan.planVersion || "n/a"),
        "生成时间：" + (plan.createdAt || "n/a"),
        "状态：" + (plan.userFriendlyStatus || "n/a"),
        "建议下一步：" + (plan.recommendedNextStep || "n/a"),
      ], (item) => item);
      appendWorkforceTerminologyConsistency(target);
      appendWorkforceDashboardSummaryCards(target, plan);
      appendWorkforcePlanOutputStructure(target, plan);
      appendWorkforceProductTemplatesPreview(target, plan.productTemplatesPreview, plan.selectedTemplate, plan.templateContext);
      appendWorkforcePlanState(target, plan.planState);
      appendWorkforceHudPreview(target, plan.workforceHudPreview);
