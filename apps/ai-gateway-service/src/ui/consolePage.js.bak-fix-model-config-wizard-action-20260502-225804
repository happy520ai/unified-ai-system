        selectedRoles: exported.selectedRoles || (taskPackage.roles || []).map((item) => item.role),
        roleTiers: exported.roleTiers || taskPackage.roleTiers || [],
        clarifyQuestions: exported.clarifyQuestions || taskPackage.clarifyQuestions || [],
        clarificationAnswers: exported.clarificationAnswers || taskPackage.clarificationAnswers || [],
        answeredClarifications: exported.answeredClarifications || taskPackage.answeredClarifications || [],
        unresolvedClarifications: exported.unresolvedClarifications || taskPackage.unresolvedClarifications || [],
        consensusPreview: exported.consensusPreview || taskPackage.consensusPreview || [],
        hookEventsPreview: exported.hookEventsPreview || taskPackage.hookEventsPreview || [],
        eventLedgerPreview: exported.eventLedgerPreview || taskPackage.eventLedgerPreview || [],
        planState: exported.planState || taskPackage.planState || null,
        lifecyclePreview: exported.lifecyclePreview || taskPackage.lifecyclePreview || null,
        reviewPackagePreview: exported.reviewPackagePreview || taskPackage.reviewPackagePreview || null,
        approvalGatePreview: exported.approvalGatePreview || taskPackage.approvalGatePreview || null,
        omxHandoffPreview: exported.omxHandoffPreview || taskPackage.omxHandoffPreview || null,
        executionReadinessPreflight: exported.executionReadinessPreflight || taskPackage.executionReadinessPreflight || null,
        externalOmxRunnerDesign: exported.externalOmxRunnerDesign || taskPackage.externalOmxRunnerDesign || null,
        runnerRequestQueuePreview: exported.runnerRequestQueuePreview || taskPackage.runnerRequestQueuePreview || null,
        executionApprovalRecordPreview: exported.executionApprovalRecordPreview || taskPackage.executionApprovalRecordPreview || null,
        externalRunnerProtocolFreeze: exported.externalRunnerProtocolFreeze || taskPackage.externalRunnerProtocolFreeze || null,
        agentWorkforcePreviewFinalUxSeal: exported.agentWorkforcePreviewFinalUxSeal || taskPackage.agentWorkforcePreviewFinalUxSeal || null,
        workforceHudPreview: exported.workforceHudPreview || taskPackage.workforceHudPreview || null,
        handoffPackageManifest: exported.handoffPackageManifest || taskPackage.handoffPackageManifest || null,
        codexDesktopHandoffPack: exported.codexDesktopHandoffPack || taskPackage.codexDesktopHandoffPack || null,
        manualCodexExecutionLoop: exported.manualCodexExecutionLoop || taskPackage.manualCodexExecutionLoop || null,
        codexResultReviewPreview: exported.codexResultReviewPreview || taskPackage.codexResultReviewPreview || null,
        safeDesktopRunnerDesign: exported.safeDesktopRunnerDesign || taskPackage.safeDesktopRunnerDesign || null,
        taskBreakdown: exported.taskBreakdown || taskPackage.taskBreakdown || [],
        deliverables: exported.deliverables || taskPackage.deliverables || [],
        acceptanceCriteria: exported.acceptanceCriteria || taskPackage.acceptanceCriteria || [],
        risks: exported.risks || taskPackage.risks || [],
        limitations: exported.limitations || taskPackage.limitations || [],
        nextActions: exported.nextActions || taskPackage.nextActions || [],
