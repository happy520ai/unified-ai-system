      setLocalAgentIntentText("local-agent-intent-files", String(fileBoundaryPreview.allowedFilesRequired !== false));
      setLocalAgentIntentText("local-agent-intent-approval-points", joinPreviewList(approvalPreview.approvalPoints || []));
      setLocalAgentIntentText("local-agent-intent-commands", joinPreviewList(commandPreview.allowedCommandPrefixes || []));
      setLocalAgentIntentText("local-agent-intent-blockers", joinPreviewList([].concat(classification.reasons || [], approvalPreview.blockers || data.blockers || [])));
      setLocalAgentIntentText("local-agent-intent-paths", joinPreviewList(fileBoundaryPreview.forbiddenPaths || []));
      setLocalAgentIntentText("local-agent-intent-next-steps", joinPreviewList(data.nextStepAdvice || []));
      writeJson("local-agent-intent-output", result);
    }

    function readApprovedLocalOperationAllowedFiles() {
      return Array.from(new Set(
        String(approvedLocalOperationFiles?.value || "")
          .split(/[\r\n,]+/)
          .map((entry) => entry.replace(/\\/g, "/").replace(/^\.\/+/, "").trim())
          .filter(Boolean),
      ));
    }

    function updateApprovedLocalOperationState(result) {
      const data = getApprovedLocalOperationData(result);
      approvedLocalOperationState = {
        ...approvedLocalOperationState,
        operationId: data.operationId || approvedLocalOperationState.operationId,
        intentPreview: data.intentPreview || approvedLocalOperationState.intentPreview,
        approvalRecord: data.approvalRecord || approvedLocalOperationState.approvalRecord,
        patchProposal: data.patchProposal || approvedLocalOperationState.patchProposal,
        applyResult: data.applyResult || approvedLocalOperationState.applyResult,
        rollbackManifest: data.rollbackManifest || data.applyResult?.rollbackManifest || approvedLocalOperationState.rollbackManifest,
        reviewResult: data.reviewResult || approvedLocalOperationState.reviewResult,
        blockers: data.blockers || approvedLocalOperationState.blockers,
        warnings: data.warnings || approvedLocalOperationState.warnings,
      };
    }

    function renderApprovedLocalOperation(result) {
      const data = getApprovedLocalOperationData(result);
      const intentPreview = data.intentPreview || approvedLocalOperationState.intentPreview || {};
      const classification = intentPreview.classification || {};
      const approvalPreview = intentPreview.approvalPreview || {};
      const approvalRecord = data.approvalRecord || approvedLocalOperationState.approvalRecord || {};
      const patchProposal = data.patchProposal || approvedLocalOperationState.patchProposal || {};
      const applyResult = data.applyResult || approvedLocalOperationState.applyResult || null;
      const rollbackManifest = data.rollbackManifest || applyResult?.rollbackManifest || approvedLocalOperationState.rollbackManifest || null;
      const reviewResult = data.reviewResult || approvedLocalOperationState.reviewResult || null;
      const blockers = [].concat(
        classification.reasons || [],
        data.blockers || [],
        approvalRecord.blockers || [],
        patchProposal.blockers || [],
      );
      const warnings = [].concat(
        data.warnings || [],
        approvalRecord.warnings || [],
        patchProposal.warnings || [],
      );

      setLocalAgentIntentText("approved-local-operation-intent-type", classification.intentType || approvalRecord.intentType || "n/a");
      setLocalAgentIntentText("approved-local-operation-risk", classification.riskLevel || approvalRecord.riskLevel || "n/a");
      setLocalAgentIntentText("approved-local-operation-recommended-mode", classification.recommendedPermissionMode || approvalRecord.permissionMode || "manual");
      setLocalAgentIntentText("approved-local-operation-blockers", joinPreviewList(blockers));
      setLocalAgentIntentText("approved-local-operation-approval-points", joinPreviewList(approvalPreview.approvalPoints || []));
      setLocalAgentIntentText("approved-local-operation-allowed-files", joinPreviewList(patchProposal.allowedFiles || approvalRecord.allowedFiles || readApprovedLocalOperationAllowedFiles()));
      setLocalAgentIntentText("approved-local-operation-diff", summarizeDiffPreview(patchProposal.diffPreview));
      setLocalAgentIntentText("approved-local-operation-apply-result", summarizeApplyResult(applyResult));
      setLocalAgentIntentText("approved-local-operation-rollback", summarizeRollbackManifest(rollbackManifest));
      setLocalAgentIntentText("approved-local-operation-review", summarizeReviewResult(reviewResult));
      setLocalAgentIntentText("approved-local-operation-warnings", joinPreviewList(warnings));
      writeJson("approved-local-operation-output", result);
    }

    function getApprovedLocalOperationData(result) {
      return result?.payload?.data || result?.payload || result || {};
    }

    function summarizeDiffPreview(diffPreview) {
      if (!Array.isArray(diffPreview) || !diffPreview.length) {
        return "n/a";
      }
      return diffPreview.slice(0, 3).map((item) => {
        if (typeof item === "string") return item.slice(0, 120);
        return (item.path || "n/a") + " length=" + String(item.proposedLength ?? item.afterLength ?? "n/a");
      }).join(" | ");
    }

    function summarizeApplyResult(applyResult) {
      if (!applyResult) {
        return "n/a";
      }
      return [
        "applied=" + Boolean(applyResult.applied),
        "dryRun=" + Boolean(applyResult.dryRun),
        "changedFiles=" + joinPreviewList(applyResult.changedFiles || []),
        "blockers=" + joinPreviewList(applyResult.blockers || []),
      ].join(" | ");
    }

    function summarizeRollbackManifest(rollbackManifest) {
      if (!rollbackManifest) {
        return "n/a";
      }
      return [
        "dryRun=" + Boolean(rollbackManifest.dryRun),
        "changedFiles=" + joinPreviewList(rollbackManifest.changedFiles || []),
        "entries=" + String((rollbackManifest.entries || []).length),
        "autoRollbackEnabled=" + Boolean(rollbackManifest.autoRollbackEnabled),
      ].join(" | ");
    }

    function summarizeReviewResult(reviewResult) {
      if (!reviewResult) {
        return "n/a";
      }
      const inner = reviewResult.reviewResult || {};
      return [
        "status=" + (inner.status || inner.decision || inner.conclusion || "review-required"),
        "dryRun=" + Boolean(reviewResult.dryRun),
        "maxRounds=" + String(reviewResult.maxRounds ?? "n/a"),
        "blockers=" + joinPreviewList(inner.blockers || []),
      ].join(" | ");
    }

    function renderEnterpriseOverview(result) {
      const target = document.getElementById("enterprise-overview-summary");
      const data = result.payload?.data;
      if (!result.ok || !data) {
        target.innerHTML = overviewLine("总览", "HTTP " + result.httpStatus, "danger") +
          overviewLine("下一步", "检查 token / auditor role", "warn");
        return;
      }
      const acceptance = data.acceptance || {};
      const releaseCandidate = data.releaseCandidate || {};
      const readiness = data.readiness || {};
      const governance = data.governance || {};
      const safety = data.safety || {};
      const safeSummary = safety.providerCalls === false &&
        safety.runtimeMutation === false &&
        safety.releaseAutomation === false &&
        safety.infrastructureProvisioning === false;

      target.innerHTML = [
        '<div class="overview-note">phase48a-enterprise-overview-readable-summary: 只读状态摘要，原始 JSON 保留在下方。</div>',
        overviewLine("总体状态", data.status || "unknown", statusTone(data.status)),
        overviewLine("企业治理", governance.authEnabled ? "auth/rbac/audit 已开启" : "auth 未开启", governance.authEnabled ? "ok" : "warn"),
        overviewLine("部署准备", readiness.deployment?.status || "unknown", statusTone(readiness.deployment?.status)),
        overviewLine("启动准备", readiness.startup?.status || "unknown", statusTone(readiness.startup?.status)),
        overviewLine("安全准备", readiness.security?.status || "unknown", statusTone(readiness.security?.status)),
        overviewLine("向量链路", (readiness.vector?.mode || "local-keyword") + " / " + (readiness.vector?.status || "unknown"), statusTone(readiness.vector?.status)),
        overviewLine("验收证据", (acceptance.passedCount ?? 0) + "/" + (acceptance.requiredCount ?? 0) + " " + (acceptance.status || "unknown"), statusTone(acceptance.status)),
        overviewLine("交付候选", (releaseCandidate.evidencePassedCount ?? 0) + "/" + (releaseCandidate.evidenceRequiredCount ?? 0) + " " + (releaseCandidate.status || "unknown"), statusTone(releaseCandidate.status)),
        overviewLine("安全边界", safeSummary ? "只读 / 无副作用" : "需要复核", safeSummary ? "ok" : "danger"),
      ].join("");
    }

    function overviewLine(label, value, tone) {
      return '<div class="overview-line"><span>' + escapeHtml(label) + '</span><strong class="status-pill status-' + escapeHtml(tone || "warn") + '">' + escapeHtml(String(value || "unknown")) + '</strong></div>';
    }

    function statusTone(value) {
      const normalized = String(value || "").toLowerCase();
      if (["ready", "passed", "ok", "running", "enabled"].includes(normalized)) return "ok";
      if (["disabled", "not-configured", "not-ready"].includes(normalized)) return "warn";
      if (["blocked", "failed", "error", "denied"].includes(normalized)) return "danger";
      return "warn";
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function readFileAsBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
          const value = String(reader.result || "");
          resolve(value.includes(",") ? value.slice(value.indexOf(",") + 1) : value);
        };
        reader.onerror = () => reject(reader.error || new Error("File read failed"));
        reader.readAsDataURL(file);
      });
    }
  </script>
</body>
</html>`;
}


