{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase327BEncryptedCredentialReference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credentialRefId",
    "ownerUserId",
    "providerId",
    "referenceType",
    "encryptedReference",
    "vaultReference",
    "envKeyName",
    "createdAt",
    "rotatedAt",
    "revokedAt",
    "status",
    "allowedScopes",
    "auditPolicy",
    "safety"
  ],
  "properties": {
    "credentialRefId": {
      "type": "string"
    },
    "ownerUserId": {
      "type": "string"
    },
    "providerId": {
      "type": "string"
    },
    "referenceType": {
      "type": "string",
      "enum": [
        "encrypted_reference",
        "vault_reference",
        "env_key_name",
        "user_secret_store_reference"
      ]
    },
    "encryptedReference": {
      "type": "string",
      "description": "Reference token only, not real ciphertext."
    },
    "vaultReference": {
      "type": "string",
      "description": "Reference token only, not a real secret."
    },
    "envKeyName": {
      "type": "string",
      "description": "Environment variable name only, never the value."
    },
    "createdAt": {
      "type": "string"
    },
    "rotatedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "revokedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reference_created",
        "pending_validation",
        "dry_run_validated",
        "revoked",
        "disabled"
      ]
    },
    "allowedScopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auditPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logReferenceIdOnly",
        "allowAuditEvents"
      ],
      "properties": {
        "logReferenceIdOnly": {
          "type": "boolean"
        },
        "allowAuditEvents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secretValueAllowed",
        "credentialRefOnly",
        "realCallsAllowed"
      ],
      "properties": {
        "secretValueAllowed": {
          "type": "boolean",
          "const": false
        },
        "credentialRefOnly": {
          "type": "boolean",
          "const": true
        },
        "realCallsAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
