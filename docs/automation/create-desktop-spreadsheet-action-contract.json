{
  "phase": "Phase1882A",
  "routeChoice": "Route A / local_self_use_only",
  "status": "contract_only_no_runtime_execution",
  "action": "create_desktop_spreadsheet",
  "description": "Owner Automation Kernel local file/table action contract for a future owner-approved desktop CSV spreadsheet creation flow.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Create Desktop Spreadsheet Action Input",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "action",
      "fileName",
      "targetDirectory",
      "columns",
      "rows",
      "openAfterCreate",
      "overwritePolicy"
    ],
    "properties": {
      "action": {
        "const": "create_desktop_spreadsheet"
      },
      "fileName": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "description": "Requested spreadsheet file name. Only .csv is in scope for the first real implementation gate."
      },
      "targetDirectory": {
        "type": "string",
        "default": "desktop",
        "enum": [
          "desktop",
          "project_evidence",
          "project_reports"
        ]
      },
      "columns": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      },
      "rows": {
        "type": "array",
        "items": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      },
      "openAfterCreate": {
        "type": "boolean",
        "default": true,
        "description": "Future runtime may open the created file only after the write gate succeeds and owner approval permits it."
      },
      "overwritePolicy": {
        "type": "string",
        "default": "never_overwrite_append_timestamp",
        "enum": [
          "never_overwrite_append_timestamp"
        ]
      }
    }
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Create Desktop Spreadsheet Action Output",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "ok",
      "action",
      "filePath",
      "fileCreated",
      "fileOpened",
      "noExistingFileOverwritten",
      "evidencePath"
    ],
    "properties": {
      "ok": {
        "type": "boolean"
      },
      "action": {
        "const": "create_desktop_spreadsheet"
      },
      "filePath": {
        "type": "string"
      },
      "fileCreated": {
        "type": "boolean"
      },
      "fileOpened": {
        "type": "boolean"
      },
      "noExistingFileOverwritten": {
        "type": "boolean"
      },
      "evidencePath": {
        "type": "string"
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "examples": {
    "input": {
      "action": "create_desktop_spreadsheet",
      "fileName": "小天任务表.csv",
      "targetDirectory": "desktop",
      "columns": [
        "任务",
        "状态",
        "备注"
      ],
      "rows": [
        [
          "示例任务",
          "待处理",
          "这是小天创建的表格"
        ],
        [
          "今天要做的事",
          "待填写",
          "你可以在这里继续编辑"
        ]
      ],
      "openAfterCreate": true,
      "overwritePolicy": "never_overwrite_append_timestamp"
    },
    "output": {
      "ok": true,
      "action": "create_desktop_spreadsheet",
      "filePath": "<desktop>\\小天任务表.csv",
      "fileCreated": true,
      "fileOpened": true,
      "noExistingFileOverwritten": true,
      "evidencePath": "apps/ai-gateway-service/evidence/phase1883a-create-desktop-spreadsheet-dry-run.json"
    }
  },
  "policy": {
    "allowedDirectories": [
      "desktop",
      "project_evidence",
      "project_reports"
    ],
    "forbiddenDirectories": [
      "legacy",
      "PROJECT_CONTEXT.md",
      ".env",
      ".git",
      "node_modules",
      "auth.json",
      "raw CredentialRef",
      "provider runtime",
      "chat route",
      "chat-gateway execute route"
    ],
    "overwriteProtection": {
      "defaultPolicy": "never_overwrite_append_timestamp",
      "existingFileBehavior": "append_timestamp",
      "noDelete": true,
      "noOverwrite": true
    },
    "network": "blocked",
    "providerCalls": "blocked",
    "secretReads": "blocked",
    "legacyScripts": "blocked",
    "desktopScan": "blocked"
  },
  "ownerOsResult": {
    "displaySurface": "Owner OS",
    "resultFields": [
      "ok",
      "action",
      "filePath",
      "fileCreated",
      "fileOpened",
      "noExistingFileOverwritten",
      "evidencePath",
      "warnings"
    ],
    "ownerMessageTemplate": "已为你准备本地表格动作结果：{filePath}。证据记录：{evidencePath}。"
  },
  "bossDailyReportIntegration": {
    "surface": "老板日报",
    "recordActionSummary": true,
    "recordEvidencePath": true,
    "noDesktopScan": true,
    "dailyReportFields": [
      "action",
      "filePath",
      "fileCreated",
      "fileOpened",
      "noExistingFileOverwritten",
      "evidencePath"
    ]
  },
  "runtimeBoundary": {
    "contractOnly": true,
    "realDesktopFileCreatedByThisPhase": false,
    "fileWriteExecutionImplementedByThisPhase": false,
    "providerCallsMade": false,
    "legacyScriptsExecuted": false
  }
}
