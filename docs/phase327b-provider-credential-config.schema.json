{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase327BProviderCredentialConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "providerId",
    "providerDisplayName",
    "enabled",
    "userOwned",
    "credentialRef",
    "credentialRefType",
    "governanceStage",
    "realCallsAllowed",
    "validationPolicy",
    "allowedModes",
    "fallbackPolicy",
    "safety"
  ],
  "properties": {
    "providerId": {
      "type": "string"
    },
    "providerDisplayName": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "userOwned": {
      "type": "boolean",
      "const": true
    },
    "credentialRef": {
      "type": "string"
    },
    "credentialRefType": {
      "type": "string"
    },
    "governanceStage": {
      "type": "string",
      "const": "shadow_config"
    },
    "realCallsAllowed": {
      "type": "boolean",
      "const": false
    },
    "validationPolicy": {
      "type": "object"
    },
    "allowedModes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallbackPolicy": {
      "type": "object"
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secretValueAllowed",
        "credentialRefOnly",
        "nonNvidiaProviderCallsAllowed"
      ],
      "properties": {
        "secretValueAllowed": {
          "type": "boolean",
          "const": false
        },
        "credentialRefOnly": {
          "type": "boolean",
          "const": true
        },
        "nonNvidiaProviderCallsAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
