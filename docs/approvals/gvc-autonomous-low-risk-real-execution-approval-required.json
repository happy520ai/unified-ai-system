    "maxMutationsPerLoop": 3,
    "maxRealExecutionLoopsPerDay": 100,
    "rollbackOnVerifierFailure": true,
    "mutationEvidenceRequired": true,
    "repairEvidenceRequired": true,
    "providerAllowed": false,
