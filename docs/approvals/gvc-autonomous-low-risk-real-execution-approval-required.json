    "verifierChain",
    "stopConditions"
  ],
  "ownerMustProvide": {
    "approvalRecordId": "",
    "approvedByOwner": false,
    "allowedMutationScopes": [
      "docs",
      "evidence",
      "verifier",
      "package scripts",
      "non-core UI repair",
      "stale cleanup",
      "history compaction",
      "local dry-run automation"
    ],
    "maxMutationsPerLoop": 3,
    "maxRealExecutionLoopsPerDay": 100,
    "rollbackPlan": "Revert the mutation batch if verifier fails or risk escalates.",
