{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yiyi Brain Response",
  "type": "object",
  "required": ["brainResponseId", "emotionState", "behaviorState", "speechBubble", "recommendedPanel", "safeSuggestion", "dryRunOnly", "providerCallsMade", "secretValueExposed", "deployExecuted", "actionExecuted"],
  "not": {
    "anyOf": [
      { "required": ["executeAction"] },
      { "required": ["readSecret"] },
      { "required": ["callProviderDirectly"] },
      { "required": ["deploy"] },
      { "required": ["modifyEvidence"] },
      { "required": ["forgeApproval"] }
    ]
  },
  "properties": {
    "brainResponseId": { "type": "string" },
    "emotionState": { "type": "string" },
    "behaviorState": { "type": "string" },
    "speechBubble": { "type": "string" },
    "explanation": { "type": "string" },
    "recommendedPanel": { "type": "string" },
    "safeSuggestion": { "type": "string" },
    "blockedReason": { "type": ["string", "null"] },
    "evidenceReference": { "type": "string" },
    "nextStepHint": { "type": "string" },
    "confidence": { "type": "string" },
    "dryRunOnly": { "const": true },
    "providerCallsMade": { "const": false },
    "secretValueExposed": { "const": false },
    "deployExecuted": { "const": false },
    "actionExecuted": { "const": false }
  }
}
